{
  "name": "ShopBoard Interview",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "forwardPorts": [3000, 5173, 3306],
  "portsAttributes": {
    "3000": { "label": "API",      "onAutoForward": "silent" },
    "5173": { "label": "Frontend", "onAutoForward": "openBrowser" },
    "3306": { "label": "MySQL",    "onAutoForward": "silent" }
  },
  "postCreateCommand": "cd backend && npm install && cd ../frontend && npm install && cd /workspace && cp backend/.env.example backend/.env && chmod +x start.sh || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-mysql"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
